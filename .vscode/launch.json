{
	"version": "0.2.0",
	"inputs": [
		{
			"id": "testEngineLaunchPath",
			"type": "command",
			"command": "cmake.launchTargetPath",
			"args": {
				"targetName": "TestEngine"
			}
		}
	],
	"configurations": [
		{
			"name": "Debug",
			"type": "lldb",
			"request": "launch",
			"program": "${workspaceFolder}/build/bin/Debug/TestEngine.exe",
			"args": [
				"${config:testEngine.launch.profileArg}"
			],
			"cwd": "${workspaceFolder}",
			"preLaunchTask": "Prelaunch Debug",
			"preTerminateCommands": [
				"nofail process kill"
			]
		},
		{
			"name": "Release",
			"type": "lldb",
			"request": "launch",
			"program": "${workspaceFolder}/build/bin/Release/TestEngine.exe",
			"args": [
				"${config:testEngine.launch.profileArg}"
			],
			"cwd": "${workspaceFolder}",
			"preLaunchTask": "Prelaunch Release",
			"preTerminateCommands": [
				"nofail process kill"
			]
		}
	]
}