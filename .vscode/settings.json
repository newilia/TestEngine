{
	"editor.formatOnSave": true,
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	"[cpp]": {
		"editor.insertSpaces": false,
		"editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
	},
	"[c]": {
		"editor.insertSpaces": false,
		"editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
	},
	"clangd.arguments": [
		"--compile-commands-dir=${workspaceFolder}/build"
	],
	"files.exclude": {
		"**/build": true
	}
}