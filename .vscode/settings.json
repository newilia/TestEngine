{
	"testEngine.launch.envArg": "--env=ballgame1",
	"cmake.options.statusBarVisibility": "hidden",
	"cmake.options.advanced": {
		"variant": {
			"statusBarVisibility": "visible"
		},
		"launchTarget": {
			"statusBarVisibility": "visible"
		}
	},
	"cmake.buildDirectory": "${workspaceFolder}/build",
	"cmake.buildBeforeRun": true,
	"cmake.debugConfig": {
		"type": "lldb",
		"request": "launch",
		"cwd": "${workspaceFolder}"
	},
	"editor.formatOnSave": true,
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	"[cpp]": {
		"editor.insertSpaces": false,
		"editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
	},
	"[c]": {
		"editor.insertSpaces": false,
		"editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
	},
	"clangd.arguments": [
		"--compile-commands-dir=${workspaceFolder}/build"
	],
	"clangd.fallbackFlags": [
		"-std=c++20",
		"--target=x86_64-pc-windows-msvc",
		"-DWIN32",
		"-D_WINDOWS",
		"-DSFML_STATIC",
		"-DIMGUI_USER_CONFIG=\"imconfig-SFML.h\"",
		"-I${workspaceFolder}/src",
		"-I${workspaceFolder}/src/Codegen",
		"-I${workspaceFolder}/third-party/SFML/include",
		"-I${workspaceFolder}/third-party/fmt/include",
		"-I${workspaceFolder}/third-party/imgui",
		"-I${workspaceFolder}/third-party/imgui-sfml",
		"-include",
		"${workspaceFolder}/src/TestEngineGlobals.h"
	],
	"files.exclude": {
		"**/build": true
	}
}